# =============================================================================
# DCMS Production Environment Template
# Document: CICD-IMPL-DCMS-001 / Environment Configs
# Version:  1.0.0
# Date:     2026-06-06
#
# IMPORTANT INSTRUCTIONS
# ──────────────────────
# 1. This file contains VAULT PATH REFERENCES, not actual secret values.
#    Do NOT store actual secrets here. Do NOT commit .env to git.
#
# 2. At container startup the Vault Agent sidecar reads each vault: reference
#    and injects the resolved value into the container environment.
#    Syntax: vault:<mount>/<path>#<field>
#    Example: vault:secret/dcms/prod/postgres#password
#
# 3. Non-secret configuration values are stored directly in this file
#    (hostnames, ports, timeouts, feature flags). These are safe to commit
#    as part of the infra repository (org/dcms-infra), NOT the application repo.
#
# 4. Lines marked [REQUIRED] MUST be provisioned in Vault before first
#    deployment. The deploy pipeline will fail if these paths are missing.
#
# 5. Vault path structure:
#      secret/dcms/prod/<service>/<key>
#    All paths assume KV v2 secrets engine mounted at 'secret/'.
#
# 6. To validate all Vault paths before a deployment run:
#      scripts/verify-vault-paths.sh prod
#
# Aligns with: ci_cd_architecture.md Section 7 (Secret Management)
#              infrastructure_architecture.md Section 8 (TLS)
# =============================================================================

# =============================================================================
# GLOBAL SETTINGS
# =============================================================================

DEPLOY_ENV=prod
LOG_LEVEL=info

# =============================================================================
# POSTGRESQL
# host/port/db are non-secrets; password is a Vault secret.
# Production connects via pgBouncer (transaction pooling, port 5432).
# =============================================================================

POSTGRES_HOST=prod-pgbouncer.internal
POSTGRES_PORT=5432
POSTGRES_DB=dcms_prod
POSTGRES_USER=dcms_app
# [REQUIRED] Vault path: secret/dcms/prod/postgres → field: password
POSTGRES_PASSWORD=vault:secret/dcms/prod/postgres#password

# Production requires verify-full for PostgreSQL client connections.
POSTGRES_SSL_MODE=verify-full

# Client TLS certificates issued by Vault PKI engine.
# [REQUIRED] Provision cert via: vault write pki/dcms-internal-ca/issue/dcms-app ...
POSTGRES_SSL_CERT_PATH=/run/secrets/pg-client-cert
POSTGRES_SSL_KEY_PATH=/run/secrets/pg-client-key
POSTGRES_SSL_ROOT_CERT_PATH=/run/secrets/dcms-ca-cert

# Production connection pool tuning (aligned with pgBouncer pool_size=50).
POSTGRES_MAX_OPEN_CONNS=40
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=10m

# =============================================================================
# REDIS
# Production: Redis Sentinel (3-node HA) — services use Sentinel-aware client.
# =============================================================================

# Sentinel addresses (comma-separated).
REDIS_SENTINEL_ADDRS=prod-redis-01.internal:26379,prod-redis-02.internal:26379,prod-redis-03.internal:26379

# Sentinel master name (matches sentinel.conf 'monitor' directive).
REDIS_SENTINEL_MASTER=dcms-prod

# Direct Redis host (fallback if Sentinel not used by a given service).
REDIS_HOST=prod-redis-01.internal
REDIS_PORT=6380    # TLS port in production (plain 6379 is disabled)

# [REQUIRED] Vault path: secret/dcms/prod/redis → field: password
REDIS_PASSWORD=vault:secret/dcms/prod/redis#password

# Redis database indices (same as dev — preserved for consistency).
REDIS_AUTH_DB=0
REDIS_CONTAINER_DB=1
REDIS_IMAGE_DB=2
REDIS_NETWORK_DB=3
REDIS_VOLUME_DB=4
REDIS_MONITOR_DB=5
REDIS_LOG_DB=6
REDIS_CLUSTER_DB=7
REDIS_NOTIFICATION_DB=8
REDIS_GATEWAY_DB=9

# Redis TLS (enabled in production).
REDIS_TLS=true
REDIS_TLS_CERT_PATH=/run/secrets/redis-client-cert
REDIS_TLS_KEY_PATH=/run/secrets/redis-client-key
REDIS_TLS_CA_PATH=/run/secrets/dcms-ca-cert

# =============================================================================
# AUTHENTICATION (auth-service)
# Production uses RS256 (RSA private key), not a shared HS256 secret.
# =============================================================================

# [REQUIRED] Vault path: secret/dcms/prod/auth → field: jwt_private_key
# Value must be a PEM-encoded RSA-2048 private key.
JWT_PRIVATE_KEY=vault:secret/dcms/prod/auth#jwt_private_key

# Path where the Vault Agent renders the private key file (read by auth-service).
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt-private-key

# JWT public key path (published at /.well-known/jwks.json).
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt-public-key

# JWT expiry settings (same as dev — adjust as per security policy).
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OIDC settings — required when ENABLE_SSO=true.
# [REQUIRED if ENABLE_SSO=true] Vault path: secret/dcms/prod/oidc → field: client_secret
OIDC_PROVIDER_URL=https://auth.example.com/realms/dcms
OIDC_CLIENT_ID=dcms-prod
OIDC_CLIENT_SECRET=vault:secret/dcms/prod/oidc#client_secret
OIDC_CALLBACK_URL=https://dcms.example.com/auth/callback
OIDC_SCOPES=openid,profile,email

MFA_ISSUER=DCMS
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_WINDOW=10m

# =============================================================================
# INTERNAL SERVICE URLs
# Production: all services communicate over Docker Swarm overlay DNS.
# Stack name prefix: dcms-prod_ (set by `docker stack deploy`)
# =============================================================================

AUTH_SERVICE_URL=http://dcms-prod_auth-service:8081
CONTAINER_SERVICE_URL=http://dcms-prod_container-service:8082
IMAGE_SERVICE_URL=http://dcms-prod_image-service:8083
NETWORK_SERVICE_URL=http://dcms-prod_network-service:8084
VOLUME_SERVICE_URL=http://dcms-prod_volume-service:8085
MONITOR_SERVICE_URL=http://dcms-prod_monitor-service:8086
LOG_SERVICE_URL=http://dcms-prod_log-service:8087
CLUSTER_SERVICE_URL=http://dcms-prod_cluster-service:8089
NOTIFICATION_SERVICE_URL=http://dcms-prod_notification-service:8088

# =============================================================================
# IMAGE SERVICE (image-service)
# =============================================================================

# [REQUIRED] Vault path: secret/dcms/prod/image-service → field: registry_encryption_key
# Value: 32-byte AES-256 key (hex-encoded). Generate with: openssl rand -hex 16
REGISTRY_CREDENTIALS_ENCRYPTION_KEY=vault:secret/dcms/prod/image-service#registry_encryption_key

TRIVY_CACHE_DIR=/tmp/trivy-cache

# Longer cache TTL in production to reduce redundant scans under load.
SCAN_RESULT_TTL=600

# =============================================================================
# AGENT (per-host Docker Engine proxy)
# =============================================================================

AGENT_GRPC_PORT=9090

# TLS certificates rendered by Vault Agent PKI sidecar.
# [REQUIRED] Issue agent cert via Vault PKI before first deployment.
AGENT_TLS_CERT_PATH=/run/secrets/agent-tls-cert
AGENT_TLS_KEY_PATH=/run/secrets/agent-tls-key
DCMS_CA_CERT_PATH=/run/secrets/dcms-ca-cert

AGENT_HEARTBEAT_INTERVAL=30s
AGENT_LOG_BUFFER_HOURS=1

# Production agents connect to Docker daemon via TCP (TLS-protected socket).
# [REQUIRED] Provision Docker TLS certs per Swarm node.
DOCKER_HOST=tcp://localhost:2376
DOCKER_TLS_VERIFY=1
DOCKER_CERT_PATH=/run/secrets/docker-client-certs

# =============================================================================
# CLUSTER SERVICE (cluster-service)
# =============================================================================

# Production: point to the Swarm manager's TLS Docker API.
SWARM_MANAGER_URL=tcp://prod-mgr-01.internal:2376

NODE_STATUS_CACHE_TTL=30s
AGENT_HEARTBEAT_TIMEOUT=45s

# =============================================================================
# MONITOR SERVICE (monitor-service)
# =============================================================================

PROMETHEUS_URL=http://dcms-prod_prometheus:9090
ALERT_CHANNEL=dcms.alerts
CONTAINER_CPU_ALERT_THRESHOLD=80
CONTAINER_MEMORY_ALERT_THRESHOLD=90

# =============================================================================
# LOG SERVICE (log-service)
# =============================================================================

LOKI_URL=http://dcms-prod_loki:3100
LOG_BATCH_SIZE=1000
LOG_BATCH_INTERVAL=1s

# =============================================================================
# NOTIFICATION SERVICE (notification-service)
# =============================================================================

# Production SMTP relay (SendGrid, SES, or internal relay).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=465
SMTP_FROM=alerts@dcms.example.com
SMTP_USERNAME=apikey
# [REQUIRED] Vault path: secret/dcms/prod/notification-service → field: smtp_password
SMTP_PASSWORD=vault:secret/dcms/prod/notification-service#smtp_password
SMTP_TLS=true

# [REQUIRED] Vault path: secret/dcms/prod/notification-service → field: slack_webhook_url
SLACK_WEBHOOK_URL=vault:secret/dcms/prod/notification-service#slack_webhook_url

NOTIFICATION_DEDUP_TTL=5m
NOTIFICATION_RETRY_MAX=5

# =============================================================================
# KONG API GATEWAY
# =============================================================================

# Admin API is NOT externally exposed in production.
# Access via bastion + SSH tunnel only.
KONG_ADMIN_PORT=8001
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# =============================================================================
# OBSERVABILITY — OpenTelemetry (all services)
# =============================================================================

OTEL_EXPORTER_OTLP_ENDPOINT=http://dcms-prod_jaeger:4318
OTEL_SERVICE_NAME=dcms
OTEL_TRACES_SAMPLER=parentbased_traceidratio

# Production: 10% sampling to reduce Jaeger storage pressure.
# Increase to 1.0 during incident investigation.
OTEL_TRACES_SAMPLER_ARG=0.1

# =============================================================================
# OBSERVABILITY — Grafana
# =============================================================================

# [REQUIRED] Vault path: secret/dcms/prod/grafana → field: admin_password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=vault:secret/dcms/prod/grafana#admin_password

# =============================================================================
# FRONTEND
# =============================================================================

VITE_API_BASE_URL=/api/v1
VITE_WS_BASE_URL=/events

# Production image references (resolved by CI during stack deploy).
IMAGE_PREFIX=ghcr.io/org/dcms
# IMAGE_TAG is injected at deploy time by the CI pipeline (sha-<git-sha>).
# Do not hardcode a tag here; leave it to be substituted by envsubst.
IMAGE_TAG=${IMAGE_TAG}

# =============================================================================
# FEATURE FLAGS
# =============================================================================

ENABLE_KUBERNETES_SUPPORT=false
ENABLE_SSO=true
ENABLE_IMAGE_SCAN_GATE=true
ENABLE_MFA=true

# =============================================================================
# VAULT (HashiCorp Vault — required in production)
# =============================================================================

# Production Vault address.
VAULT_ADDR=https://prod-vault-01.internal:8200

# AppRole credentials. The role_id is mounted as a Docker Secret.
# The secret_id is rotated every 30 days by Vault Agent.
# [REQUIRED] Each service has its own AppRole. Provision before first deploy.
VAULT_ROLE_ID_PATH=/run/secrets/vault-role-id
VAULT_SECRET_ID_PATH=/run/secrets/vault-secret-id

# PKI engine path for mTLS certificate issuance.
VAULT_PKI_PATH=pki/dcms-internal-ca

VAULT_SECRET_LEASE_DURATION=1h

# Vault Agent sidecar renew interval (must be < VAULT_SECRET_LEASE_DURATION).
VAULT_AGENT_RENEW_INCREMENT=900

# =============================================================================
# TLS (production mTLS enforcement)
# =============================================================================

# All inter-service HTTP calls in production use mTLS.
# Certificate paths are populated by Vault Agent PKI sidecar.
SERVICE_TLS_CERT_PATH=/run/secrets/service-tls-cert
SERVICE_TLS_KEY_PATH=/run/secrets/service-tls-key
SERVICE_TLS_CA_PATH=/run/secrets/dcms-ca-cert

# Minimum TLS version for all inbound and outbound connections.
TLS_MIN_VERSION=TLS1.3

# =============================================================================
# DEPLOYMENT METADATA (injected by CI pipeline at deploy time)
# =============================================================================

# These are substituted by envsubst in the deploy job; do not set static values.
# DEPLOY_SHA    — git SHA of the deployed commit
# DEPLOY_TIME   — ISO 8601 timestamp of the deploy
# DEPLOY_BY     — GitHub Actions actor who triggered the deployment
DEPLOY_SHA=${DEPLOY_SHA}
DEPLOY_TIME=${DEPLOY_TIME}
DEPLOY_BY=${DEPLOY_BY}

# =============================================================================
# VAULT PATH INVENTORY — Quick Reference
# All [REQUIRED] paths that must be provisioned before first deployment.
# Run: scripts/verify-vault-paths.sh prod
# =============================================================================
#
# secret/dcms/prod/postgres
#   password          — PostgreSQL application user password
#
# secret/dcms/prod/redis
#   password          — Redis AUTH password
#
# secret/dcms/prod/auth
#   jwt_private_key   — RSA-2048 PEM private key for JWT RS256 signing
#
# secret/dcms/prod/oidc                     (if ENABLE_SSO=true)
#   client_secret     — OIDC provider client secret
#
# secret/dcms/prod/image-service
#   registry_encryption_key  — AES-256 key for registry credential encryption
#
# secret/dcms/prod/notification-service
#   smtp_password     — SMTP relay API key or password
#   slack_webhook_url — Slack incoming webhook URL
#
# secret/dcms/prod/grafana
#   admin_password    — Grafana admin UI password
#
# PKI certificates (issued on demand by Vault PKI; not stored as KV secrets):
#   pki/dcms-internal-ca/issue/dcms-app    — PostgreSQL client cert
#   pki/dcms-internal-ca/issue/agent       — Agent gRPC mTLS cert per host
#   pki/dcms-internal-ca/issue/api-server  — api-server mTLS server cert
#
# Docker Secrets (set via: docker secret create <name> <file>):
#   dcms-registry-secret     — ghcr.io pull credentials for Swarm nodes
#   dcms-<svc>-vault-role-id — Vault AppRole role_id per service
# =============================================================================

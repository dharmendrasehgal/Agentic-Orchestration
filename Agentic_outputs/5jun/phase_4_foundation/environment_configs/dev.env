# =============================================================================
# DCMS Development Environment Configuration
# Document: CICD-IMPL-DCMS-001 / Environment Configs
# Version:  1.0.0
# Date:     2026-06-06
#
# Usage:
#   cp environment_configs/dev.env .env
#   # Edit .env and set real values where noted.
#   docker compose up
#
# IMPORTANT: Never commit .env to git.
# This file (dev.env) contains SAFE DEFAULTS only — no real secrets.
# Add .env to .gitignore immediately.
# =============================================================================

# =============================================================================
# GLOBAL SETTINGS
# =============================================================================

# Runtime environment identifier. Used in log output and telemetry.
# Values: dev | staging | prod
DEPLOY_ENV=dev

# Logging verbosity for all Go services and Kong.
# Values: debug | info | warn | error
LOG_LEVEL=debug

# =============================================================================
# POSTGRESQL
# Connection settings for all services that require a database.
# =============================================================================

# Hostname of the PostgreSQL instance.
# In docker compose this resolves to the 'postgres' service via Docker DNS.
POSTGRES_HOST=postgres

# PostgreSQL port (default: 5432).
POSTGRES_PORT=5432

# Database name. Created automatically by the postgres init container.
POSTGRES_DB=dcms_dev

# Database superuser (used by init scripts and migration runner).
POSTGRES_USER=dcms

# Database password. CHANGE THIS even for local dev if the port is exposed.
# In CI this is overridden by the test matrix.
POSTGRES_PASSWORD=changeme_dev_only

# SSL mode for PostgreSQL connections.
# dev: disable (no TLS cert management needed locally)
# staging/prod: require or verify-full
POSTGRES_SSL_MODE=disable

# Client TLS certificate paths (used only when POSTGRES_SSL_MODE=verify-full).
POSTGRES_SSL_CERT_PATH=/certs/pg-client.crt
POSTGRES_SSL_KEY_PATH=/certs/pg-client.key
POSTGRES_SSL_ROOT_CERT_PATH=/certs/ca.crt

# Connection pool settings (shared defaults; override per service if needed).
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=5m

# Host-mapped port for psql / DBeaver access from the developer machine.
# Ignored by docker compose networking (internal port is always 5432).
POSTGRES_HOST_PORT=5432

# =============================================================================
# REDIS
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379

# Redis AUTH password. Leave empty to disable authentication in dev.
# In staging/prod this MUST be set.
REDIS_PASSWORD=

# Redis database indices per service (0-15). Isolation prevents key collisions.
REDIS_AUTH_DB=0
REDIS_CONTAINER_DB=1
REDIS_IMAGE_DB=2
REDIS_NETWORK_DB=3
REDIS_VOLUME_DB=4
REDIS_MONITOR_DB=5
REDIS_LOG_DB=6
REDIS_CLUSTER_DB=7
REDIS_NOTIFICATION_DB=8
REDIS_GATEWAY_DB=9

# Host-mapped port for redis-cli access from the developer machine.
REDIS_HOST_PORT=6379

# =============================================================================
# AUTHENTICATION (auth-service)
# =============================================================================

# JWT signing secret. Must be at least 32 characters.
# In production this is an RSA private key path, not a shared secret.
# REQUIRED: Generate with: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-minimum-32-chars-here-replace-me

# Access token lifetime.
JWT_EXPIRY=15m

# Refresh token lifetime.
JWT_REFRESH_EXPIRY=7d

# OIDC (SSO) settings — leave blank to disable SSO in dev.
# Set ENABLE_SSO=true and fill these in to test OIDC integration locally.
OIDC_PROVIDER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:8080/auth/callback
OIDC_SCOPES=openid,profile,email

# MFA (TOTP) issuer name shown in authenticator apps.
MFA_ISSUER=DCMS-Dev

# Account lockout policy.
# Lock account after N consecutive failures within the window.
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_WINDOW=10m

# =============================================================================
# INTERNAL SERVICE URLs
# These are used by services that call other DCMS services via HTTP.
# In docker compose, service names resolve via Docker internal DNS.
# =============================================================================

AUTH_SERVICE_URL=http://auth-service:8081
CONTAINER_SERVICE_URL=http://container-service:8082
IMAGE_SERVICE_URL=http://image-service:8083
NETWORK_SERVICE_URL=http://network-service:8084
VOLUME_SERVICE_URL=http://volume-service:8085
MONITOR_SERVICE_URL=http://monitor-service:8086
LOG_SERVICE_URL=http://log-service:8087
CLUSTER_SERVICE_URL=http://cluster-service:8089
NOTIFICATION_SERVICE_URL=http://notification-service:8088

# =============================================================================
# IMAGE SERVICE (image-service)
# =============================================================================

# Encryption key for registry credentials stored at rest in PostgreSQL.
# Must be 32 bytes (AES-256). Generate with: openssl rand -hex 16
# In production this key is managed by Vault.
REGISTRY_CREDENTIALS_ENCRYPTION_KEY=dev-encryption-key-32-chars-here

# Directory where Trivy caches its vulnerability database.
TRIVY_CACHE_DIR=/tmp/trivy-cache

# How long (seconds) to cache Trivy scan results in Redis before rescanning.
SCAN_RESULT_TTL=300

# =============================================================================
# AGENT (per-host Docker Engine proxy)
# =============================================================================

# gRPC server port on the agent binary.
AGENT_GRPC_PORT=9090

# TLS certificate paths for agent gRPC mTLS.
# In dev: use self-signed certs generated by ./scripts/gen-dev-certs.sh
# In prod: certificates issued by Vault PKI engine.
AGENT_TLS_CERT_PATH=/certs/agent.crt
AGENT_TLS_KEY_PATH=/certs/agent.key
DCMS_CA_CERT_PATH=/certs/ca.crt

# How often the agent sends a heartbeat to cluster-service.
AGENT_HEARTBEAT_INTERVAL=30s

# How long to buffer container logs locally when log-service is unreachable.
AGENT_LOG_BUFFER_HOURS=1

# Local Docker daemon socket. Override to use a remote Docker host via TCP.
DOCKER_HOST=unix:///var/run/docker.sock

# =============================================================================
# CLUSTER SERVICE (cluster-service)
# =============================================================================

# Swarm manager URL. Leave blank in dev (uses local Docker socket).
# In staging/prod, set to the manager node's Docker TLS API endpoint.
SWARM_MANAGER_URL=

# How long to cache node status in Redis.
NODE_STATUS_CACHE_TTL=30s

# How long without a heartbeat before marking an agent as offline.
AGENT_HEARTBEAT_TIMEOUT=45s

# =============================================================================
# MONITOR SERVICE (monitor-service)
# =============================================================================

PROMETHEUS_URL=http://prometheus:9090

# Redis pub/sub channel for alert events.
ALERT_CHANNEL=dcms.alerts

# Alert threshold percentages (0-100).
CONTAINER_CPU_ALERT_THRESHOLD=80
CONTAINER_MEMORY_ALERT_THRESHOLD=90

# =============================================================================
# LOG SERVICE (log-service)
# =============================================================================

LOKI_URL=http://loki:3100

# Loki push batch tuning.
LOG_BATCH_SIZE=1000
LOG_BATCH_INTERVAL=1s

# =============================================================================
# NOTIFICATION SERVICE (notification-service)
# =============================================================================

# SMTP settings — dev routes all email through Mailhog (port 1025).
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=dcms-noreply@localhost
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=false

# Slack outbound webhook (leave blank to skip Slack delivery in dev).
SLACK_WEBHOOK_URL=

# How long to suppress duplicate alert notifications.
NOTIFICATION_DEDUP_TTL=5m

# Maximum retry attempts for failed notification delivery.
NOTIFICATION_RETRY_MAX=5

# =============================================================================
# KONG API GATEWAY
# =============================================================================

# Kong admin API port (host-mapped; do NOT expose in production).
KONG_ADMIN_PORT=8001

# Kong proxy ports.
KONG_HTTP_PORT=8080
KONG_HTTPS_PORT=8443

# =============================================================================
# OBSERVABILITY — OpenTelemetry (all services)
# =============================================================================

# OTLP endpoint for distributed traces. In dev this points to Jaeger.
# In staging/prod, point to your OTel Collector or Jaeger endpoint.
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318

# Service name added to all spans. Overridden per-service by SERVICE_NAME env.
OTEL_SERVICE_NAME=dcms

# Trace sampling ratio (1.0 = 100%, 0.1 = 10%).
# Use 1.0 in dev for full traceability; reduce in production.
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# =============================================================================
# OBSERVABILITY — Prometheus / Grafana
# =============================================================================

# Grafana admin credentials for the dev stack.
# These are ONLY used by Grafana itself (not by DCMS services).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# FRONTEND
# =============================================================================

# API base URL injected into the Vite build (prefix for all API calls).
VITE_API_BASE_URL=/api/v1

# SSE (Server-Sent Events) endpoint base URL.
VITE_WS_BASE_URL=/events

# Image prefix and tag used by docker compose to resolve pre-built images.
# In CI this is set to ghcr.io/<owner>/dcms and sha-<git-sha> respectively.
IMAGE_PREFIX=dcms
IMAGE_TAG=dev

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Set to true to enable Kubernetes API adapter in cluster-service and agent.
# Requires additional Kubeconfig secrets (not configured for v1).
ENABLE_KUBERNETES_SUPPORT=false

# Set to true to enable OIDC-based single sign-on via auth-service.
# Requires OIDC_PROVIDER_URL, OIDC_CLIENT_ID, OIDC_CLIENT_SECRET to be set.
ENABLE_SSO=false

# Set to true to enforce image scan gate (CRITICAL CVEs block container create).
# Recommended: true in staging/prod; can be false in dev for faster iteration.
ENABLE_IMAGE_SCAN_GATE=true

# Set to true to enable MFA enforcement for admin-role users.
ENABLE_MFA=false

# =============================================================================
# VAULT (HashiCorp Vault — optional in dev, required in staging/prod)
# =============================================================================

# Leave VAULT_ADDR blank in dev to skip Vault integration.
# When blank, services fall back to env var secrets.
VAULT_ADDR=
VAULT_TOKEN=

# AppRole credentials path (used by Vault agent sidecar in staging/prod).
VAULT_ROLE_ID_PATH=/run/secrets/vault-role-id
VAULT_SECRET_ID_PATH=/run/secrets/vault-secret-id

# PKI engine path for mTLS certificate issuance.
VAULT_PKI_PATH=pki/dcms-internal-ca

# Lease duration for secrets retrieved from Vault.
VAULT_SECRET_LEASE_DURATION=1h

{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "phase": "3 - Domain Design",
    "system": "Docker Container Management System (DCMS)",
    "agent": "ui_ux_agent",
    "date": "2026-06-05",
    "version": "1.0.0",
    "tailwindConfigKey": "theme.extend"
  },

  "colors": {
    "primary": {
      "50":  { "$value": "#eff6ff", "$type": "color", "$description": "Lightest blue - hover backgrounds" },
      "100": { "$value": "#dbeafe", "$type": "color" },
      "200": { "$value": "#bfdbfe", "$type": "color" },
      "300": { "$value": "#93c5fd", "$type": "color" },
      "400": { "$value": "#60a5fa", "$type": "color" },
      "500": { "$value": "#3b82f6", "$type": "color", "$description": "Primary brand blue - buttons, links" },
      "600": { "$value": "#2563eb", "$type": "color", "$description": "Primary hover state" },
      "700": { "$value": "#1d4ed8", "$type": "color" },
      "800": { "$value": "#1e40af", "$type": "color", "$description": "Primary dark - sidebar accents" },
      "900": { "$value": "#1e3a8a", "$type": "color", "$description": "Primary darkest - dark sidebar bg" },
      "950": { "$value": "#172554", "$type": "color" }
    },

    "neutral": {
      "50":  { "$value": "#f8fafc", "$type": "color", "$description": "Page background light mode" },
      "100": { "$value": "#f1f5f9", "$type": "color", "$description": "Card background light mode" },
      "150": { "$value": "#e9eff5", "$type": "color" },
      "200": { "$value": "#e2e8f0", "$type": "color", "$description": "Border light mode" },
      "300": { "$value": "#cbd5e1", "$type": "color" },
      "400": { "$value": "#94a3b8", "$type": "color", "$description": "Placeholder text" },
      "500": { "$value": "#64748b", "$type": "color", "$description": "Secondary text" },
      "600": { "$value": "#475569", "$type": "color" },
      "700": { "$value": "#334155", "$type": "color", "$description": "Primary text light mode" },
      "800": { "$value": "#1e293b", "$type": "color", "$description": "Card background dark mode" },
      "850": { "$value": "#172032", "$type": "color" },
      "900": { "$value": "#0f172a", "$type": "color", "$description": "Page background dark mode" },
      "950": { "$value": "#020617", "$type": "color", "$description": "Sidebar background dark mode" }
    },

    "semantic": {
      "success": {
        "light": { "$value": "#16a34a", "$type": "color" },
        "DEFAULT": { "$value": "#22c55e", "$type": "color", "$description": "Success green" },
        "dark":  { "$value": "#4ade80", "$type": "color", "$description": "Success green dark mode" },
        "bg":    { "$value": "#f0fdf4", "$type": "color", "$description": "Success background light" },
        "bgDark":{ "$value": "#052e16", "$type": "color", "$description": "Success background dark" },
        "border":{ "$value": "#86efac", "$type": "color" }
      },
      "warning": {
        "light": { "$value": "#d97706", "$type": "color" },
        "DEFAULT": { "$value": "#f59e0b", "$type": "color", "$description": "Warning amber" },
        "dark":  { "$value": "#fbbf24", "$type": "color", "$description": "Warning amber dark mode" },
        "bg":    { "$value": "#fffbeb", "$type": "color" },
        "bgDark":{ "$value": "#2d1900", "$type": "color" },
        "border":{ "$value": "#fcd34d", "$type": "color" }
      },
      "error": {
        "light": { "$value": "#dc2626", "$type": "color" },
        "DEFAULT": { "$value": "#ef4444", "$type": "color", "$description": "Error red" },
        "dark":  { "$value": "#f87171", "$type": "color", "$description": "Error red dark mode" },
        "bg":    { "$value": "#fef2f2", "$type": "color" },
        "bgDark":{ "$value": "#2d0a0a", "$type": "color" },
        "border":{ "$value": "#fca5a5", "$type": "color" }
      },
      "info": {
        "light": { "$value": "#0284c7", "$type": "color" },
        "DEFAULT": { "$value": "#0ea5e9", "$type": "color", "$description": "Info sky blue" },
        "dark":  { "$value": "#38bdf8", "$type": "color", "$description": "Info sky blue dark mode" },
        "bg":    { "$value": "#f0f9ff", "$type": "color" },
        "bgDark":{ "$value": "#012030", "$type": "color" },
        "border":{ "$value": "#7dd3fc", "$type": "color" }
      }
    },

    "status": {
      "running": {
        "text":   { "$value": "#16a34a", "$type": "color" },
        "bg":     { "$value": "#dcfce7", "$type": "color" },
        "dot":    { "$value": "#22c55e", "$type": "color" },
        "textDark": { "$value": "#4ade80", "$type": "color" },
        "bgDark": { "$value": "#052e16", "$type": "color" }
      },
      "stopped": {
        "text":   { "$value": "#475569", "$type": "color" },
        "bg":     { "$value": "#f1f5f9", "$type": "color" },
        "dot":    { "$value": "#94a3b8", "$type": "color" },
        "textDark": { "$value": "#94a3b8", "$type": "color" },
        "bgDark": { "$value": "#1e293b", "$type": "color" }
      },
      "error": {
        "text":   { "$value": "#dc2626", "$type": "color" },
        "bg":     { "$value": "#fef2f2", "$type": "color" },
        "dot":    { "$value": "#ef4444", "$type": "color" },
        "textDark": { "$value": "#f87171", "$type": "color" },
        "bgDark": { "$value": "#2d0a0a", "$type": "color" }
      },
      "paused": {
        "text":   { "$value": "#b45309", "$type": "color" },
        "bg":     { "$value": "#fffbeb", "$type": "color" },
        "dot":    { "$value": "#f59e0b", "$type": "color" },
        "textDark": { "$value": "#fbbf24", "$type": "color" },
        "bgDark": { "$value": "#2d1900", "$type": "color" }
      },
      "starting": {
        "text":   { "$value": "#0284c7", "$type": "color" },
        "bg":     { "$value": "#f0f9ff", "$type": "color" },
        "dot":    { "$value": "#0ea5e9", "$type": "color" },
        "textDark": { "$value": "#38bdf8", "$type": "color" },
        "bgDark": { "$value": "#012030", "$type": "color" }
      },
      "removing": {
        "text":   { "$value": "#9333ea", "$type": "color" },
        "bg":     { "$value": "#faf5ff", "$type": "color" },
        "dot":    { "$value": "#a855f7", "$type": "color" },
        "textDark": { "$value": "#c084fc", "$type": "color" },
        "bgDark": { "$value": "#1a0d2e", "$type": "color" }
      },
      "dead": {
        "text":   { "$value": "#991b1b", "$type": "color" },
        "bg":     { "$value": "#fef2f2", "$type": "color" },
        "dot":    { "$value": "#b91c1c", "$type": "color" },
        "textDark": { "$value": "#fca5a5", "$type": "color" },
        "bgDark": { "$value": "#2d0a0a", "$type": "color" }
      }
    },

    "dark": {
      "surface": {
        "base":   { "$value": "#0f172a", "$type": "color", "$description": "Dark mode page background" },
        "raised": { "$value": "#1e293b", "$type": "color", "$description": "Dark mode card background" },
        "overlay":{ "$value": "#334155", "$type": "color", "$description": "Dark mode modal / dropdown bg" },
        "sunken": { "$value": "#020617", "$type": "color", "$description": "Dark mode sidebar / deeply nested" }
      },
      "text": {
        "primary":   { "$value": "#f1f5f9", "$type": "color" },
        "secondary": { "$value": "#94a3b8", "$type": "color" },
        "disabled":  { "$value": "#475569", "$type": "color" }
      },
      "border": {
        "default": { "$value": "#334155", "$type": "color" },
        "subtle":  { "$value": "#1e293b", "$type": "color" }
      }
    }
  },

  "typography": {
    "fontFamily": {
      "sans": {
        "$value": "'Inter', 'ui-sans-serif', system-ui, -apple-system, sans-serif",
        "$type": "fontFamily",
        "$description": "Primary UI font"
      },
      "mono": {
        "$value": "'JetBrains Mono', 'ui-monospace', 'Cascadia Code', monospace",
        "$type": "fontFamily",
        "$description": "Code, logs, terminal output"
      }
    },

    "fontSize": {
      "xs":   { "$value": "0.75rem",   "$type": "dimension", "$description": "12px - labels, meta text" },
      "sm":   { "$value": "0.875rem",  "$type": "dimension", "$description": "14px - secondary content" },
      "base": { "$value": "1rem",      "$type": "dimension", "$description": "16px - body text" },
      "lg":   { "$value": "1.125rem",  "$type": "dimension", "$description": "18px - card headings" },
      "xl":   { "$value": "1.25rem",   "$type": "dimension", "$description": "20px - section headings" },
      "2xl":  { "$value": "1.5rem",    "$type": "dimension", "$description": "24px - page headings" },
      "3xl":  { "$value": "1.875rem",  "$type": "dimension", "$description": "30px - stat numbers" },
      "4xl":  { "$value": "2.25rem",   "$type": "dimension", "$description": "36px - hero numbers" }
    },

    "fontWeight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight", "$description": "Table column values" },
      "semibold": { "$value": 600, "$type": "fontWeight", "$description": "Card headings, labels" },
      "bold":     { "$value": 700, "$type": "fontWeight", "$description": "Page headings, stat numbers" }
    },

    "lineHeight": {
      "tight":  { "$value": 1.25, "$type": "number", "$description": "Headings" },
      "snug":   { "$value": 1.375, "$type": "number" },
      "normal": { "$value": 1.5,   "$type": "number", "$description": "Body text" },
      "relaxed":{ "$value": 1.625, "$type": "number", "$description": "Log output" },
      "loose":  { "$value": 2.0,   "$type": "number", "$description": "Table rows" }
    },

    "letterSpacing": {
      "tight":  { "$value": "-0.015em", "$type": "dimension" },
      "normal": { "$value": "0em",      "$type": "dimension" },
      "wide":   { "$value": "0.025em",  "$type": "dimension", "$description": "Status badge labels (uppercase)" },
      "wider":  { "$value": "0.05em",   "$type": "dimension" }
    }
  },

  "spacing": {
    "$description": "4px base grid. spacing-N = N * 4px",
    "0":  { "$value": "0px",    "$type": "dimension" },
    "px": { "$value": "1px",    "$type": "dimension" },
    "0.5":{ "$value": "2px",    "$type": "dimension" },
    "1":  { "$value": "4px",    "$type": "dimension" },
    "1.5":{ "$value": "6px",    "$type": "dimension" },
    "2":  { "$value": "8px",    "$type": "dimension" },
    "2.5":{ "$value": "10px",   "$type": "dimension" },
    "3":  { "$value": "12px",   "$type": "dimension" },
    "3.5":{ "$value": "14px",   "$type": "dimension" },
    "4":  { "$value": "16px",   "$type": "dimension", "$description": "Base unit - icon gutters" },
    "5":  { "$value": "20px",   "$type": "dimension" },
    "6":  { "$value": "24px",   "$type": "dimension", "$description": "Card padding vertical" },
    "7":  { "$value": "28px",   "$type": "dimension" },
    "8":  { "$value": "32px",   "$type": "dimension", "$description": "Section padding" },
    "9":  { "$value": "36px",   "$type": "dimension" },
    "10": { "$value": "40px",   "$type": "dimension" },
    "11": { "$value": "44px",   "$type": "dimension" },
    "12": { "$value": "48px",   "$type": "dimension", "$description": "Page top padding" },
    "14": { "$value": "56px",   "$type": "dimension" },
    "16": { "$value": "64px",   "$type": "dimension", "$description": "Section vertical spacing" },
    "20": { "$value": "80px",   "$type": "dimension" },
    "24": { "$value": "96px",   "$type": "dimension" },
    "32": { "$value": "128px",  "$type": "dimension" },
    "40": { "$value": "160px",  "$type": "dimension" },
    "48": { "$value": "192px",  "$type": "dimension" },
    "56": { "$value": "224px",  "$type": "dimension" },
    "64": { "$value": "256px",  "$type": "dimension" },

    "component": {
      "cardPaddingX":     { "$value": "24px", "$type": "dimension", "$description": "Card horizontal padding (spacing-6)" },
      "cardPaddingY":     { "$value": "20px", "$type": "dimension", "$description": "Card vertical padding (spacing-5)" },
      "tableRowHeight":   { "$value": "52px", "$type": "dimension", "$description": "Standard table row height - also virtualizer estimateSize" },
      "tableRowHeightSm": { "$value": "40px", "$type": "dimension", "$description": "Compact table row height" },
      "tableHeaderHeight":{ "$value": "44px", "$type": "dimension" },
      "sidebarWidth":     { "$value": "240px","$type": "dimension" },
      "sidebarCollapsedWidth": { "$value": "64px", "$type": "dimension" },
      "topbarHeight":     { "$value": "56px", "$type": "dimension" },
      "modalMaxWidth":    { "$value": "560px","$type": "dimension" },
      "modalMaxWidthLg":  { "$value": "800px","$type": "dimension" },
      "inputHeight":      { "$value": "40px", "$type": "dimension" },
      "inputHeightSm":    { "$value": "32px", "$type": "dimension" },
      "buttonHeight":     { "$value": "40px", "$type": "dimension" },
      "buttonHeightSm":   { "$value": "32px", "$type": "dimension" },
      "buttonHeightLg":   { "$value": "48px", "$type": "dimension" },
      "badgeHeight":      { "$value": "22px", "$type": "dimension" },
      "avatarSm":         { "$value": "28px", "$type": "dimension" },
      "avatarMd":         { "$value": "36px", "$type": "dimension" },
      "avatarLg":         { "$value": "48px", "$type": "dimension" }
    }
  },

  "borderRadius": {
    "none": { "$value": "0px",     "$type": "dimension" },
    "sm":   { "$value": "4px",     "$type": "dimension", "$description": "Badges, chips, small buttons" },
    "md":   { "$value": "6px",     "$type": "dimension", "$description": "Input fields, default buttons" },
    "lg":   { "$value": "8px",     "$type": "dimension", "$description": "Cards, dropdowns" },
    "xl":   { "$value": "12px",    "$type": "dimension", "$description": "Modals, large panels" },
    "2xl":  { "$value": "16px",    "$type": "dimension" },
    "full": { "$value": "9999px",  "$type": "dimension", "$description": "Pills, avatars, circular buttons" }
  },

  "shadows": {
    "sm": {
      "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "$type": "shadow",
      "$description": "Subtle element lift - input fields, badges"
    },
    "md": {
      "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
      "$type": "shadow",
      "$description": "Dropdown menus, tooltips"
    },
    "lg": {
      "$value": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
      "$type": "shadow",
      "$description": "Raised panels"
    },
    "card": {
      "$value": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1)",
      "$type": "shadow",
      "$description": "Standard card shadow"
    },
    "cardHover": {
      "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
      "$type": "shadow",
      "$description": "Card shadow on hover"
    },
    "modal": {
      "$value": "0 25px 50px -12px rgba(0, 0, 0, 0.25)",
      "$type": "shadow",
      "$description": "Modal dialog shadow"
    },
    "sidebar": {
      "$value": "1px 0 0 0 rgba(0, 0, 0, 0.08)",
      "$type": "shadow",
      "$description": "Sidebar right border shadow"
    },
    "topbar": {
      "$value": "0 1px 0 0 rgba(0, 0, 0, 0.08)",
      "$type": "shadow",
      "$description": "Topbar bottom border shadow"
    },
    "inner": {
      "$value": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.05)",
      "$type": "shadow",
      "$description": "Sunken input / well effect"
    }
  },

  "breakpoints": {
    "sm":  { "$value": "640px",  "$type": "dimension", "$description": "Mobile landscape" },
    "md":  { "$value": "768px",  "$type": "dimension", "$description": "Tablet portrait" },
    "lg":  { "$value": "1024px", "$type": "dimension", "$description": "Tablet landscape / small laptop" },
    "xl":  { "$value": "1280px", "$type": "dimension", "$description": "Desktop - primary design target" },
    "2xl": { "$value": "1536px", "$type": "dimension", "$description": "Wide desktop / monitoring dashboard" }
  },

  "animation": {
    "duration": {
      "instant": { "$value": "50ms",   "$type": "duration", "$description": "Micro feedback (button press)" },
      "fast":    { "$value": "100ms",  "$type": "duration", "$description": "Tooltip appear, badge update" },
      "normal":  { "$value": "200ms",  "$type": "duration", "$description": "Dropdown open, status badge change" },
      "slow":    { "$value": "300ms",  "$type": "duration", "$description": "Modal enter, page transition" },
      "slower":  { "$value": "500ms",  "$type": "duration", "$description": "Chart line draw, skeleton fade" },
      "lazy":    { "$value": "700ms",  "$type": "duration", "$description": "Complex layout transition" }
    },
    "easing": {
      "linear":    { "$value": "linear",                        "$type": "cubicBezier" },
      "in":        { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier", "$description": "Elements leaving screen" },
      "out":       { "$value": "cubic-bezier(0, 0, 0.2, 1)",   "$type": "cubicBezier", "$description": "Elements entering screen" },
      "inOut":     { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier", "$description": "Elements moving on screen" },
      "spring":    { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier", "$description": "Playful bounce - notifications" },
      "overshoot": { "$value": "cubic-bezier(0.175, 0.885, 0.32, 1.275)", "$type": "cubicBezier" }
    },
    "keyframes": {
      "fadeIn":    { "$value": "fadeIn 200ms ease-out",     "$type": "string" },
      "fadeOut":   { "$value": "fadeOut 150ms ease-in",     "$type": "string" },
      "slideDown": { "$value": "slideDown 200ms ease-out",  "$type": "string", "$description": "Dropdown open" },
      "slideUp":   { "$value": "slideUp 150ms ease-in",     "$type": "string", "$description": "Dropdown close" },
      "pulse":     { "$value": "pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite", "$type": "string", "$description": "Status dot for 'starting' state" },
      "spin":      { "$value": "spin 1s linear infinite",   "$type": "string", "$description": "Loading spinner" },
      "shimmer":   { "$value": "shimmer 1.5s ease-in-out infinite", "$type": "string", "$description": "Skeleton loading" }
    }
  },

  "zIndex": {
    "hide":     { "$value": -1,   "$type": "number" },
    "auto":     { "$value": 0,    "$type": "number" },
    "base":     { "$value": 1,    "$type": "number" },
    "raised":   { "$value": 10,   "$type": "number", "$description": "Sticky table headers" },
    "sticky":   { "$value": 20,   "$type": "number", "$description": "Sticky sidebar, topbar" },
    "dropdown": { "$value": 100,  "$type": "number", "$description": "Select menus, action menus" },
    "overlay":  { "$value": 200,  "$type": "number", "$description": "Modal backdrop" },
    "modal":    { "$value": 300,  "$type": "number", "$description": "Modal dialog" },
    "tooltip":  { "$value": 400,  "$type": "number", "$description": "Tooltips (above modals)" },
    "toast":    { "$value": 500,  "$type": "number", "$description": "Toast notifications (topmost)" },
    "max":      { "$value": 9999, "$type": "number", "$description": "Emergency override" }
  },

  "opacity": {
    "disabled":   { "$value": 0.38, "$type": "number", "$description": "Disabled controls" },
    "dimmed":     { "$value": 0.6,  "$type": "number", "$description": "Secondary elements" },
    "overlay":    { "$value": 0.5,  "$type": "number", "$description": "Modal backdrop" },
    "hover":      { "$value": 0.08, "$type": "number", "$description": "Hover state bg overlay" },
    "focus":      { "$value": 0.12, "$type": "number", "$description": "Focus state bg overlay" }
  },

  "size": {
    "icon": {
      "xs":  { "$value": "12px", "$type": "dimension" },
      "sm":  { "$value": "16px", "$type": "dimension", "$description": "Inline icons" },
      "md":  { "$value": "20px", "$type": "dimension", "$description": "Button icons" },
      "lg":  { "$value": "24px", "$type": "dimension", "$description": "Navigation icons" },
      "xl":  { "$value": "32px", "$type": "dimension", "$description": "Empty state icons" },
      "2xl": { "$value": "48px", "$type": "dimension", "$description": "Hero / error state icons" }
    },
    "chart": {
      "sparklineHeight": { "$value": "48px",  "$type": "dimension" },
      "cardChartHeight": { "$value": "120px", "$type": "dimension" },
      "pageChartHeight": { "$value": "240px", "$type": "dimension" },
      "fullChartHeight": { "$value": "360px", "$type": "dimension" }
    }
  },

  "border": {
    "width": {
      "none":   { "$value": "0px", "$type": "dimension" },
      "thin":   { "$value": "1px", "$type": "dimension", "$description": "Standard border" },
      "medium": { "$value": "2px", "$type": "dimension", "$description": "Focus ring, active tab indicator" },
      "thick":  { "$value": "4px", "$type": "dimension", "$description": "Left accent bar on selected sidebar item" }
    },
    "color": {
      "default":  { "$value": "{colors.neutral.200}", "$type": "color" },
      "subtle":   { "$value": "{colors.neutral.100}", "$type": "color" },
      "strong":   { "$value": "{colors.neutral.300}", "$type": "color" },
      "focus":    { "$value": "{colors.primary.500}", "$type": "color" },
      "error":    { "$value": "{colors.semantic.error.DEFAULT}", "$type": "color" },
      "success":  { "$value": "{colors.semantic.success.DEFAULT}", "$type": "color" }
    }
  }
}

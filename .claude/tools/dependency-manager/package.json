{
  "name": "dependency-manager-cli",
  "version": "1.0.0",
  "description": "CLI to enforce canonical lockfile policies and run per-track dry-run sandboxes",
  "bin": {
    "depman": "index.js"
  },
  "scripts": {
    "check-lock":      "node index.js check-lock",
    "dry-run":         "node index.js dry-run",
    "propose-upgrade": "node index.js propose-upgrade",
    "emergency-lock":  "node index.js emergency-lock"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {}
}
